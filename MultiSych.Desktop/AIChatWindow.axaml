<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MultiSych.Desktop.ViewModels;assembly=MultiSych.Desktop"
        x:Class="MultiSych.Desktop.AIChatWindow"
        x:DataType="vm:AIChatViewModel"
        Title="AI Chat"
        Width="800" Height="600"
        Background="{DynamicResource PrimaryBackgroundBrush}">
  <DockPanel LastChildFill="True" Margin="0">
    <!-- Header -->
    <Border DockPanel.Dock="Top" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,15">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
          <TextBlock Text="✨" FontSize="24" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding ProviderDisplayName}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
        </StackPanel>
        <Button Grid.Column="1" Content="⚙️ Settings" Command="{Binding ToggleSettingsCommand}" Background="Transparent" Foreground="{DynamicResource TextBrush}"/>
      </Grid>
    </Border>

    <!-- Main Content -->
    <Grid RowDefinitions="Auto, *, Auto" Margin="20">
      
      <!-- Settings Panel -->
      <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12" Padding="15" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,15">
        <StackPanel Spacing="12">
          <TextBlock Text="Configuration" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
          <Grid ColumnDefinitions="Auto,*,Auto,Auto" RowDefinitions="Auto,Auto" Margin="0,5,0,0">
            
            <TextBlock Grid.Row="0" Grid.Column="0" Text="API Key:" VerticalAlignment="Center" Margin="0,0,10,10" Foreground="{DynamicResource TextBrush}"/>
            <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding ApiKey, Mode=TwoWay}" PasswordChar="•" Margin="0,0,10,10"/>
            <Button Grid.Row="0" Grid.Column="3" Content="Save Key" Command="{Binding UpdateApiKeyCommand}" Margin="0,0,0,10" Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentTextBrush}"/>
            
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Model:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource TextBrush}"/>
            <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding AvailableModels}" SelectedItem="{Binding SelectedModel}" HorizontalAlignment="Stretch" Margin="0,0,10,0"/>
            <TextBlock Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Text="{Binding SettingsStatus}" Foreground="{DynamicResource TextBrush}" Opacity="0.7" VerticalAlignment="Center" TextAlignment="Right"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Chat History -->
      <ScrollViewer Grid.Row="1" Background="Transparent" Margin="0,0,0,15">
        <ItemsControl ItemsSource="{Binding ChatMessages}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Background="{DynamicResource SecondaryBackgroundBrush}" CornerRadius="12" Padding="15" Margin="0,0,0,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <TextBlock Grid.Column="0" Text="{Binding SenderName}" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}" FontSize="12" Foreground="{DynamicResource TextBrush}" Opacity="0.5"/>
                  </Grid>
                  <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" LineHeight="22"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Input Area -->
      <Grid Grid.Row="2" ColumnDefinitions="*, Auto">
        <TextBox Grid.Column="0" PlaceholderText="Message AI Assistant..." Text="{Binding CurrentMessage, Mode=TwoWay}"
                 HorizontalAlignment="Stretch" AcceptsReturn="True" MinHeight="60" MaxHeight="150" TextWrapping="Wrap" Margin="0,0,10,0" CornerRadius="8"/>
                 
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Bottom">
          <Button Command="{Binding ToggleRecordingCommand}" Width="60" Height="60" CornerRadius="30" Background="{DynamicResource SecondaryBackgroundBrush}" Foreground="{DynamicResource TextBrush}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ToolTip.Tip="Record Voice">
            <TextBlock Text="{Binding RecordButtonText}" FontSize="24"/>
          </Button>
          <Button Command="{Binding SendMessageCommand}" 
                  Width="60" Height="60" CornerRadius="30"
                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentTextBrush}">
            <TextBlock Text="➤" FontSize="24" Margin="2,0,0,0"/>
          </Button>
        </StackPanel>
      </Grid>
    </Grid>
  </DockPanel>
</Window>
